{
  "name": "@antidrift/cascade",
  "version": "0.1.0",
  "description": "Provider-chained isomorphic data layer for Cloudflare Workers + browser",
  "type": "module",
  "exports": {
    ".":                     { "types": "./dist/index.d.ts",                   "import": "./dist/index.js" },
    "./core":                { "types": "./dist/core/index.d.ts",              "import": "./dist/core/index.js" },
    "./providers/cf-cache":  { "types": "./dist/providers/cf-cache.d.ts",     "import": "./dist/providers/cf-cache.js" },
    "./providers/d1":        { "types": "./dist/providers/d1.d.ts",           "import": "./dist/providers/d1.js" },
    "./providers/kv":        { "types": "./dist/providers/kv.d.ts",           "import": "./dist/providers/kv.js" },
    "./providers/indexeddb": { "types": "./dist/providers/indexeddb.d.ts",    "import": "./dist/providers/indexeddb.js" }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250205.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "dexie": "^4.0.0"
  },
  "peerDependencies": {
    "dexie": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "dexie": { "optional": true }
  }
}
